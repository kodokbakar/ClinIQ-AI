# NODE ENV
NODE_ENV=local

# CORS Configuration
ALLOWED_ORIGINS=*

# DB (PostgreSQL)
DB_USER=postgres
DB_PASS=*
DB_NAME=cliniq_ai
DB_HOST=127.0.0.1
DB_PORT=5432
DB_CONNECTION=postgres
DB_SSL=false

# REDIS
REDIS_HOST=*
REDIS_PORT=10227
REDIS_PASSWORD=*

# S3
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=true
AWS_ENDPOINT=

# JWT
JWT_KEY=supersecretkeymy

# AI (9Router)
AI_BASE_URL=http://localhost:20128/v1
AI_API_KEY=*
AI_MODEL=cf/@cf/meta/llama-3.1-8b-instruct-fp8-fast
AI_CHAT_COMPLETIONS_PATH=/chat/completions
AI_PROVIDER_NAME=9Router
AI_REQUEST_TIMEOUT_MS=60000
